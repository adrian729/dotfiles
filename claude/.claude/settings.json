{
  "permissions": {
    "allow": [
      "Read",
      "Read(//**)",
      "Grep",
      "Glob",
      "WebFetch",
      "WebSearch",
      "Bash(llm *)",
      "Bash(llm-probe*)",
      "Bash(ollama ps*)",
      "Bash(ollama list*)",
      "Bash(ollama run*)",
      "Bash(ollama show*)",
      "Bash(opencode-task*)",
      "Bash(opencode-llm*)",
      "Bash(opencode-models *)",
      "Bash(opencode-agent-models-probe *)",
      "Bash(cat *)",
      "Bash(bat *)",
      "Bash(ls *)",
      "Bash(find *)",
      "Bash(rg *)",
      "Bash(grep *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(awk *)",
      "Bash(sed *)",
      "Bash(wc *)",
      "Bash(sort *)",
      "Bash(uniq *)",
      "Bash(du *)",
      "Bash(df *)",
      "Bash(pwd *)",
      "Bash(which *)",
      "Bash(type *)",
      "Bash(command -v*)",
      "Bash(whoami *)",
      "Bash(date *)",
      "Bash(ps *)",
      "Bash(printenv *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git status *)",
      "Bash(git show *)"
    ],
    "deny": [
      "Bash(git push*)"
    ],
    "ask": [
      "Bash(git commit *)",
      "Bash(npm publish*)",
      "Bash(gh release*)",
      "Bash(docker push*)",
      "Bash(terraform apply*)",
      "Bash(kubectl apply*)",
      "Bash(cargo publish*)"
    ]
  },
  "model": "sonnet",
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/skill-eval.sh"
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/agent-eval.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Agent|Task",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/agent-guard.sh"
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/agent-skill-nudge.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh"
  },
  "enabledPlugins": {
    "pyright-lsp@claude-plugins-official": true,
    "rust-analyzer-lsp@claude-plugins-official": true,
    "lua-lsp@claude-plugins-official": true,
    "clangd-lsp@claude-plugins-official": true
  },
  "effortLevel": "high",
  "autoMemoryEnabled": false,
  "skipWorkflowUsageWarning": true,
  "theme": "dark-ansi",
  "editorMode": "vim",
  "skipAutoPermissionPrompt": true,
  "skillOverrides": {
    "autonomous-process": "name-only",
    "audit-loop": "name-only",
    "best-of-n": "name-only",
    "evaluator-optimizer": "name-only"
  }
}
