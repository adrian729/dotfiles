{
  "permissions": {
    "allow": [
      "Read",
      "Grep",
      "Glob",
      "Bash(llm *)",
      "Bash(llm-probe*)",
      "Bash(ollama ps*)",
      "Bash(ollama list*)"
    ],
    "deny": [
      "Bash(git push*)"
    ],
    "ask": [
      "Bash(npm publish*)",
      "Bash(gh release*)",
      "Bash(docker push*)",
      "Bash(terraform apply*)",
      "Bash(kubectl apply*)",
      "Bash(cargo publish*)"
    ]
  },
  "model": "opus[1m]",
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/skill-eval.sh"
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/agent-eval.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Agent|Task",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/agent-guard.sh"
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/agent-skill-nudge.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh"
  },
  "enabledPlugins": {
    "pyright-lsp@claude-plugins-official": true,
    "rust-analyzer-lsp@claude-plugins-official": true,
    "lua-lsp@claude-plugins-official": true,
    "clangd-lsp@claude-plugins-official": true
  },
  "effortLevel": "high",
  "autoMemoryEnabled": false,
  "skipWorkflowUsageWarning": true,
  "theme": "dark-ansi",
  "editorMode": "vim",
  "skipAutoPermissionPrompt": true
}
