#!/usr/bin/env bash
# opencode-llm — delegate token-heavy micro-task to free-tier cloud model via OpenCode relay.
# Same contract as `llm`. Prefer `llm` first (free, offline); use this when local disabled.
set -euo pipefail

AGENT="relay"
NEUTRAL_DIR="$HOME/.local/state/agents/opencode-llm-cwd"
STATE_FILE="$HOME/.local/state/agents/opencode-llm.json"
CONFIG_FILE="$HOME/.local/config/opencode-llm-models.json"

FALLBACK_MODELS=(
  opencode/deepseek-v4-flash-free
  opencode/mimo-v2.5-free
  opencode/hy3-free
  opencode/big-pickle
)

die() { echo "opencode-llm: $*" >&2; exit 1; }

usage() {
  cat >&2 <<'EOF'
Usage: opencode-llm [flags] PROMPT...   # stdin (optional) = content to operate on
  -m MODEL     force provider/model (e.g. opencode/big-pickle), no fallback walk
  -T SECS      request timeout (default 300)
  -o FILE      write the response to FILE; stdout prints only a receipt line
Exit: 0 ok · 1 usage · 2 input empty · 3 opencode/jq missing · 5 no candidate model
      · 6 API error · 124 timeout
EOF
  exit 1
}


FORCE_MODEL=""
TIMEOUT=300
OUTFILE=""
PROMPT_PARTS=()
while [ $# -gt 0 ]; do
  case "$1" in
    -m) [ $# -ge 2 ] || usage; FORCE_MODEL="$2"; shift 2 ;;
    -T) [ $# -ge 2 ] || usage; TIMEOUT="$2"; shift 2 ;;
    -o) [ $# -ge 2 ] || usage; OUTFILE="$2"; shift 2 ;;
    --) shift; while [ $# -gt 0 ]; do PROMPT_PARTS+=("$1"); shift; done ;;
    -*) echo "opencode-llm: unknown flag: $1" >&2; usage ;;
    *) PROMPT_PARTS+=("$1"); shift ;;
  esac
done
[ ${#PROMPT_PARTS[@]} -gt 0 ] || usage
PROMPT="${PROMPT_PARTS[*]}"

case "$TIMEOUT" in *[!0-9]*|'') die "invalid -T (seconds): $TIMEOUT" ;; esac

command -v opencode >/dev/null 2>&1 || { echo "opencode-llm: opencode CLI not found" >&2; exit 3; }
command -v jq >/dev/null 2>&1 || { echo "opencode-llm: jq required" >&2; exit 3; }

mkdir -p "$NEUTRAL_DIR" || die "could not create $NEUTRAL_DIR"

# --- portable timeout wrapper (macOS has no `timeout`) -----------------------
TIMEOUT_BIN=""
if command -v timeout >/dev/null 2>&1; then TIMEOUT_BIN="timeout"
elif command -v gtimeout >/dev/null 2>&1; then TIMEOUT_BIN="gtimeout"
fi

# Caller MUST invoke this with errexit off (bracket with set +e / set -e) —
# it deliberately returns non-zero on timeout, and `wait`/`kill` on an already
# -gone watcher job are expected to fail harmlessly. Runs CMD in its own
# process group so a timeout kill reaches any children it spawns, not just
# the immediate process.
run_timed() { # run_timed SECS CMD...  — returns 124 on timeout
  local secs="$1"; shift
  if [ -n "$TIMEOUT_BIN" ]; then
    "$TIMEOUT_BIN" "$secs" "$@"
    return $?
  fi
  local marker; marker=$(mktemp "${TMPDIR:-/tmp}/opencode-llm.timeout.XXXXXX")
  rm -f "$marker"
  set -m
  "$@" &
  local pid=$!
  set +m
  ( sleep "$secs" 2>/dev/null
    if kill -0 "$pid" 2>/dev/null; then
      if kill -TERM "-$pid" 2>/dev/null || kill -TERM "$pid" 2>/dev/null; then
        : > "$marker"
      fi
    fi
  ) &
  local watcher=$!
  wait "$pid" 2>/dev/null
  local rc=$?
  kill "$watcher" 2>/dev/null || true
  wait "$watcher" 2>/dev/null || true
  if [ -f "$marker" ]; then rm -f "$marker"; return 124; fi
  return "$rc"
}

STDIN_FILE=$(mktemp "${TMPDIR:-/tmp}/opencode-llm.stdin.XXXXXX")
RESP_FILE=$(mktemp "${TMPDIR:-/tmp}/opencode-llm.resp.XXXXXX")
trap 'rm -f "$STDIN_FILE" "$RESP_FILE"' EXIT
if [ ! -t 0 ]; then
  cat > "$STDIN_FILE"
fi

FULL_PROMPT="$PROMPT"
if [ -s "$STDIN_FILE" ]; then
  FULL_PROMPT="$PROMPT

<content>
$(cat "$STDIN_FILE")
</content>

Answer the request above the content."
fi
[ -n "$FULL_PROMPT" ] || { echo "opencode-llm: empty prompt and empty stdin" >&2; exit 2; }


# opencode/big-pickle is solid but runs ~70-80s per call (heavy hidden
# reasoning) — kept only as a last resort. deepseek-v4-flash-free /
# mimo-v2.5-free answer in ~2s; hy3-free ~10s.
# The model chain is tuned per-machine by opencode-llm-probe at install time.
MODELS=()
load_models() {
  if [ -n "$FORCE_MODEL" ]; then
    MODELS=("$FORCE_MODEL")
    return
  fi
  if [ -f "$STATE_FILE" ]; then
    while IFS= read -r m; do [ -n "$m" ] && MODELS+=("$m"); done \
      < <(jq -r '.models[]?' "$STATE_FILE" 2>/dev/null)
  fi
  if [ ${#MODELS[@]} -eq 0 ] && [ -f "$CONFIG_FILE" ]; then
    while IFS= read -r m; do [ -n "$m" ] && MODELS+=("$m"); done \
      < <(jq -r '.preferred[]?' "$CONFIG_FILE" 2>/dev/null)
  fi
  if [ ${#MODELS[@]} -eq 0 ]; then
    MODELS=("${FALLBACK_MODELS[@]}")
    echo "opencode-llm: no model config found — using built-in fallback" >&2
  fi
}
load_models


tried=""
n=${#MODELS[@]}
i=0
while [ "$i" -lt "$n" ]; do
  model="${MODELS[$i]}"
  tried="${tried:+$tried, }$model"

  set +e
  run_timed "$TIMEOUT" opencode run -m "$model" --agent "$AGENT" --dir "$NEUTRAL_DIR" --format json -- "$FULL_PROMPT" >"$RESP_FILE" 2>/dev/null
  rc=$?
  set -e

  if [ "$rc" -eq 124 ]; then
    echo "opencode-llm: request timed out after ${TIMEOUT}s (model $model)" >&2
    exit 124
  fi

  errmsg=$(jq -r 'select(.type=="error") | (.error.data.message // .error.name // "unknown error")' "$RESP_FILE" 2>/dev/null | head -1)

  if [ "$rc" -eq 0 ] && [ -z "$errmsg" ] && [ -s "$RESP_FILE" ]; then
    # Dedupe by part.id, keeping the last (assumed-cumulative) text per id,
    # in first-seen order — safe whether or not a part streams multiple
    # snapshots before completion.
    resp=$(jq -rs '
      [.[] | select(.type=="text")]
      | reduce .[] as $e ({}; .[$e.part.id] = $e.part.text)
      | to_entries | .[].value
    ' "$RESP_FILE" 2>/dev/null)
    if [ -n "$resp" ]; then
      if [ -n "$OUTFILE" ]; then
        printf '%s\n' "$resp" > "$OUTFILE" || die "could not write $OUTFILE"
        echo "wrote $(printf '%s\n' "$resp" | wc -l | tr -d ' ') lines to $OUTFILE"
      else
        printf '%s\n' "$resp"
      fi
      exit 0
    fi
  fi

  # Any failure (bad model, auth, rate limit, empty response): walk to the
  # next candidate. With -m forced there is no next candidate — surface it.
  if [ -n "$FORCE_MODEL" ]; then
    echo "opencode-llm: request failed (model $model): ${errmsg:-exit $rc}" >&2
    exit 6
  fi
  if [ $(( i + 1 )) -lt "$n" ]; then
    echo "opencode-llm: model $model unavailable (${errmsg:-exit $rc}), falling back to ${MODELS[$((i+1))]}" >&2
  fi
  i=$(( i + 1 ))
done

echo "opencode-llm: no candidate model available (tried: $tried) — fall back to Claude" >&2
exit 5
