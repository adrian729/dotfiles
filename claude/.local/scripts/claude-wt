#!/usr/bin/env bash
# claude-wt — start or resume a named Claude Code session in its own git worktree.
set -euo pipefail

COLOR_NAMES="red maroon peach yellow green teal sky sapphire blue lavender mauve pink flamingo rosewater"

# Catppuccin Mocha base (#1e1e2e) blended ~20% toward each accent: dark enough
# to keep text readable, distinct enough to tell panes apart.
tint_for() {
  case "$1" in
    red)       echo "#493446" ;;
    maroon)    echo "#473847" ;;
    peach)     echo "#4a3c40" ;;
    yellow)    echo "#4a4548" ;;
    green)     echo "#394545" ;;
    teal)      echo "#36454f" ;;
    sky)       echo "#334454" ;;
    sapphire)  echo "#2f4054" ;;
    blue)      echo "#333c57" ;;
    lavender)  echo "#3c3e58" ;;
    mauve)     echo "#413956" ;;
    pink)      echo "#493f53" ;;
    flamingo)  echo "#48414e" ;;
    rosewater) echo "#494551" ;;
    *) return 1 ;;
  esac
}

usage() {
  cat <<EOF
Usage:
  claude-wt <name> [color]    Start or resume Claude session <name> in its own
                              worktree (<repo>/.claude/worktrees/<name>, branch
                              <name>). Re-running the same command resumes the
                              session; the color is remembered per name. When
                              the session exits with unpushed commits, offers
                              to push and open/update a draft PR.
  claude-wt -l, --list        List this repo's session worktrees.
  claude-wt -d, --done <name> Remove a worktree when finished; offers local
                              branch deletion once its PR is merged.
  claude-wt -h, --help        Show this help.

Colors (tmux pane background tint; terminal background outside tmux):
  $COLOR_NAMES
EOF
}

die() {
  echo "claude-wt: $*" >&2
  exit 1
}

main_root() {
  local common
  common=$(git rev-parse --path-format=absolute --git-common-dir 2>/dev/null) ||
    die "not inside a git repository"
  dirname "$common"
}

has_origin() {
  git -C "$1" remote get-url origin >/dev/null 2>&1
}

ensure_excluded() {
  local exclude="$1/.git/info/exclude"
  mkdir -p "$(dirname "$exclude")"
  grep -qxF '.claude/worktrees/' "$exclude" 2>/dev/null ||
    echo '.claude/worktrees/' >>"$exclude"
}

copy_worktreeinclude() {
  local root=$1 wt_dir=$2 f
  [ -f "$root/.worktreeinclude" ] || return 0
  git -C "$root" ls-files -o -i --exclude-from="$root/.worktreeinclude" -z |
    while IFS= read -r -d '' f; do
      case "$f" in */) continue ;; esac # embedded git repos list as 'dir/'
      mkdir -p "$wt_dir/$(dirname "$f")"
      cp "$root/$f" "$wt_dir/$f" ||
        echo "claude-wt: warning: could not copy $f into the worktree" >&2
    done
}

# Claude stores transcripts under ~/.claude/projects/<cwd with every
# non-alphanumeric char replaced by '-'>; a *.jsonl there means this worktree
# already has a session to continue.
has_session() {
  local encoded
  encoded=$(printf '%s' "$1" | sed 's/[^A-Za-z0-9]/-/g')
  ls "$HOME/.claude/projects/$encoded"/*.jsonl >/dev/null 2>&1
}

# Capture the previous pane/window state so reset_color restores it instead
# of forcing defaults — resetting to "default" would wipe the tint of an
# outer claude-wt session, and rename-window disables tmux's automatic-rename
# for the window permanently.
apply_color() {
  local name=$1 tint=$2
  [ -n "$tint" ] || return 0
  if [ -n "${TMUX:-}" ]; then
    prev_pane_bg=$(tmux display -p '#{pane_bg}' 2>/dev/null || true)
    prev_win_name=$(tmux display -p '#{window_name}' 2>/dev/null || true)
    prev_autorename=$(tmux show -wv automatic-rename 2>/dev/null || true)
    tmux select-pane -P "bg=$tint" 2>/dev/null || true
    tmux rename-window "$name" 2>/dev/null || true
  else
    printf '\033]11;%s\007' "$tint"
  fi
}

reset_color() {
  if [ -n "${TMUX:-}" ]; then
    tmux select-pane -P "bg=${prev_pane_bg:-default}" 2>/dev/null || true
    [ -n "${prev_win_name:-}" ] &&
      tmux rename-window "$prev_win_name" 2>/dev/null || true
    if [ -n "${prev_autorename:-}" ]; then
      tmux set -w automatic-rename "$prev_autorename" 2>/dev/null || true
    else
      tmux set -wu automatic-rename 2>/dev/null || true
    fi
  else
    printf '\033]111\007'
  fi
}

# After the session ends, offer to push new commits and open/update the
# branch's draft PR. Claude sessions are denied `git push` by settings.json,
# so this wrapper is where pushing happens. Runs inside the worktree.
offer_push_pr() {
  local name=$1 base count dirty ans url
  has_origin . || return 0
  if git rev-parse --verify --quiet '@{u}' >/dev/null; then
    base='@{u}'
  elif git rev-parse --verify --quiet origin/HEAD >/dev/null; then
    base=origin/HEAD
  else
    return 0
  fi
  count=$(git rev-list --count "$base"..HEAD)
  [ "$count" -gt 0 ] || return 0

  echo ""
  echo "Session '$name' has $count unpushed commit(s):"
  git log --oneline --no-decorate "$base"..HEAD | sed 's/^/  /'
  git diff --shortstat "$base" HEAD | sed 's/^ */  /'
  dirty=$(git status --porcelain | wc -l | tr -d ' ')
  [ "$dirty" -gt 0 ] && echo "  note: $dirty uncommitted file(s) will stay local"
  printf 'Push and open/update draft PR? [Y/n] '
  read -r ans || ans=n # EOF (non-interactive stdin) → don't push
  case "$ans" in
    n | N | no | NO)
      echo "Not pushed — resume with: claude-wt $name"
      return 0
      ;;
  esac

  if ! git push -u origin "$name"; then
    echo "claude-wt: warning: push failed — retry with: git push -u origin $name" >&2
    return 0
  fi
  if command -v gh >/dev/null 2>&1; then
    if url=$(gh pr view "$name" --json url -q .url 2>/dev/null); then
      echo "PR updated: $url"
    elif gh pr create --fill --draft; then
      :
    else
      echo "claude-wt: warning: could not create the PR via gh — use the URL from the push output" >&2
    fi
  fi
}

cmd_list() {
  local root=$1 prefix path branch name color dirty line
  prefix="$root/.claude/worktrees/"
  printf '%-20s %-20s %-8s %s\n' NAME BRANCH COLOR STATE
  git -C "$root" worktree list --porcelain | while IFS= read -r line; do
    case "$line" in
      "worktree "*)
        path=${line#worktree }
        continue
        ;;
      "branch refs/heads/"*) branch=${line#branch refs/heads/} ;;
      detached) branch="(detached)" ;;
      *) continue ;;
    esac
    case "$path" in
      "$prefix"*)
        name=${path#"$prefix"}
        color=$(git -C "$root" config --get "claude-wt.$name.color" 2>/dev/null || echo -)
        if [ -n "$(git -C "$path" status --porcelain 2>/dev/null)" ]; then
          dirty=dirty
        else
          dirty=clean
        fi
        printf '%-20s %-20s %-8s %s\n' "$name" "$branch" "$color" "$dirty"
        ;;
    esac
  done
}

cmd_done() {
  local root=$1 name=$2 wt_dir ans state="" parent
  wt_dir="$root/.claude/worktrees/$name"
  [ -d "$wt_dir" ] || die "no worktree named '$name' (see claude-wt -l)"
  [ -f "$wt_dir/.git" ] ||
    die "'$name' exists but is not a worktree (try: git worktree prune)"
  if [ -n "$(git -C "$wt_dir" status --porcelain)" ]; then
    echo "Worktree '$name' has uncommitted changes:"
    git -C "$wt_dir" status --short
    printf 'Remove anyway and DISCARD these changes? [y/N] '
    read -r ans || ans=n # EOF → abort, keep the worktree
    case "$ans" in
      y | Y | yes | YES) git -C "$root" worktree remove --force "$wt_dir" ;;
      *) die "aborted" ;;
    esac
  else
    git -C "$root" worktree remove "$wt_dir"
  fi
  git -C "$root" config --unset "claude-wt.$name.color" 2>/dev/null || true
  # Slashed names (feat/x) leave empty parent dirs behind — remove them up to
  # the worktrees root so they can't shadow future session names.
  parent=$(dirname "$wt_dir")
  while [ "$parent" != "$root/.claude/worktrees" ] && rmdir "$parent" 2>/dev/null; do
    parent=$(dirname "$parent")
  done
  echo "Removed worktree '$name'."
  if command -v gh >/dev/null 2>&1; then
    state=$(cd "$root" && gh pr view "$name" --json state -q .state 2>/dev/null || true)
  fi
  if [ "$state" = "MERGED" ]; then
    printf "Its PR is merged — delete local branch '%s' too? [Y/n] " "$name"
    read -r ans || ans=n # EOF → keep the branch
    case "$ans" in
      n | N | no | NO) echo "Branch kept." ;;
      *) git -C "$root" branch -D "$name" ;;
    esac
  else
    echo "Branch kept:"
    echo "  not pushed yet?     git push -u origin $name"
    echo "  PR merged? delete:  git branch -D $name   (squash-merges need -D, not -d)"
  fi
}

cmd_start() {
  local root=$1 name=$2 color=$3 wt_dir tint="" created="" base
  git check-ref-format --branch "$name" >/dev/null 2>&1 ||
    die "'$name' is not a valid branch name"
  if [ -n "$color" ]; then
    tint=$(tint_for "$color") || die "unknown color '$color' (valid: $COLOR_NAMES)"
  fi
  wt_dir="$root/.claude/worktrees/$name"

  ensure_excluded "$root"

  if [ ! -d "$wt_dir" ]; then
    git -C "$root" worktree prune
    # New branches should start from the latest remote default branch, not a
    # stale origin/HEAD snapshot — fetch only on create, never on resume.
    if has_origin "$root"; then
      if git -C "$root" fetch --quiet origin; then
        git -C "$root" rev-parse --verify --quiet origin/HEAD >/dev/null ||
          git -C "$root" remote set-head origin --auto >/dev/null 2>&1 || true
      else
        echo "claude-wt: warning: fetch failed — branching from last-known origin/HEAD" >&2
      fi
    fi
    if git -C "$root" show-ref --verify --quiet "refs/heads/$name"; then
      echo "Branch '$name' exists — reattaching it to a new worktree."
      git -C "$root" worktree add "$wt_dir" "$name"
    else
      if git -C "$root" rev-parse --verify --quiet origin/HEAD >/dev/null; then
        base=origin/HEAD
      else
        base=HEAD
      fi
      git -C "$root" worktree add "$wt_dir" -b "$name" "$base"
    fi
    copy_worktreeinclude "$root" "$wt_dir"
    created=1
  elif [ ! -f "$wt_dir/.git" ]; then
    # Without this guard a leftover folder here (e.g. the empty parent a
    # slashed name leaves behind) would start an UN-isolated session running
    # directly on the main checkout.
    die "'$name' exists but is not a worktree (leftover folder? try: git worktree prune, or pick another name)"
  fi

  if [ -n "$color" ]; then
    git -C "$root" config "claude-wt.$name.color" "$color"
  else
    color=$(git -C "$root" config --get "claude-wt.$name.color" 2>/dev/null || true)
    if [ -n "$color" ]; then
      tint=$(tint_for "$color") || true
    fi
  fi

  cd "$wt_dir"
  apply_color "$name" "$tint"
  [ -n "$tint" ] && trap reset_color EXIT

  if [ -z "$created" ] && has_session "$wt_dir"; then
    claude --continue || true
  else
    claude -n "$name" || true
  fi

  offer_push_pr "$name"
}

case "${1:-}" in
  -h | --help)
    usage
    exit 0
    ;;
  -l | --list)
    [ $# -eq 1 ] || {
      usage >&2
      exit 1
    }
    # Assign first: die inside "$(main_root)" used as an argument runs in a
    # subshell and would NOT stop the script; a failing assignment does.
    root=$(main_root)
    cmd_list "$root"
    ;;
  -d | --done)
    [ $# -eq 2 ] || {
      usage >&2
      exit 1
    }
    root=$(main_root)
    cmd_done "$root" "$2"
    ;;
  "" | -*)
    usage >&2
    exit 1
    ;;
  *)
    [ $# -le 2 ] || {
      usage >&2
      exit 1
    }
    root=$(main_root)
    cmd_start "$root" "$1" "${2:-}"
    ;;
esac
