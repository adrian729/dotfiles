#!/usr/bin/env bash
# open-wt — open an editor in a claude-wt session worktree.
# Usage: open-wt <editor> <name>   e.g. open-wt nvim feature-auth
#                                       open-wt code feature-auth
set -euo pipefail

usage() {
  cat <<EOF
Usage:
  open-wt <editor> <name>  Open <editor> in session worktree <name>, e.g.:
                             open-wt code feature-auth
                             open-wt nvim feature-auth
  open-wt -h, --help       Show this help.

Worktrees live under <repo>/.claude/worktrees/ (list them: claude-wt -l).
EOF
}

die() {
  echo "open-wt: $*" >&2
  exit 1
}

case "${1:-}" in
  -h | --help)
    usage
    exit 0
    ;;
  "" | -*)
    usage >&2
    exit 1
    ;;
esac

[ $# -ge 2 ] || { usage >&2; exit 1; }

editor=$1
name=$2

common=$(git rev-parse --path-format=absolute --git-common-dir 2>/dev/null) ||
  die "not inside a git repository"
root=$(dirname "$common")

wt_dir="$root/.claude/worktrees/$name"
[ -d "$wt_dir" ] || die "no worktree named '$name' (see claude-wt -l)"
[ -f "$wt_dir/.git" ] || die "'$name' exists but is not a worktree (try: git worktree prune)"

cd "$wt_dir" && exec "$editor" .
