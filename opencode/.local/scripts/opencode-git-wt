#!/usr/bin/env bash
# opencode-git-wt — run a git command inside an opencode-wt session worktree.
set -euo pipefail

usage() {
  cat <<EOF
Usage:
  opencode-git-wt <name> <git args...>  Run git in session worktree <name>, e.g.:
                                           opencode-git-wt feature-auth status --short
                                           opencode-git-wt feature-auth diff
  opencode-git-wt -h, --help            Show this help.

Worktrees live under <repo>/.opencode/worktrees/ (list them: opencode-wt -l).
EOF
}

die() {
  echo "opencode-git-wt: $*" >&2
  exit 1
}

case "${1:-}" in
  -h | --help)
    usage
    exit 0
    ;;
  "" | -*)
    usage >&2
    exit 1
    ;;
esac
[ $# -ge 2 ] || { usage >&2; exit 1; }

common=$(git rev-parse --path-format=absolute --git-common-dir 2>/dev/null) ||
  die "not inside a git repository"
root=$(dirname "$common")

name=$1
shift
wt_dir="$root/.opencode/worktrees/$name"
[ -d "$wt_dir" ] || die "no worktree named '$name' (see opencode-wt -l)"
[ -f "$wt_dir/.git" ] || die "'$name' exists but is not a worktree (try: git worktree prune)"

exec git -C "$wt_dir" "$@"
