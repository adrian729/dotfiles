#!/usr/bin/env bash
# opencode-llm-probe — verify opencode-llm's preferred model list against
# what the OpenCode CLI actually offers. Best-effort: if auth fails, output
# can't be parsed, or the CLI isn't available, writes the static preferred
# list as-is with a note.
#
# Runs at install time (opencode/install.sh). Writes
# ~/.local/state/agents/opencode-llm.json. Non-fatal — install proceeds.
set -euo pipefail

STATE_DIR="$HOME/.local/state/agents"
STATE_FILE="$STATE_DIR/opencode-llm.json"
CONFIG_FILE="$HOME/.local/config/opencode-llm-models.json"

die() { echo "opencode-llm-probe: $*" >&2; exit 1; }

mkdir -p "$STATE_DIR" || die "could not create $STATE_DIR"

PROBED_AT=$(date -u +%Y-%m-%dT%H:%M:%SZ)

# --- read preferred list from config -----------------------------------------
if [ -f "$CONFIG_FILE" ]; then
  mapfile -t PREFERRED < <(jq -r '.preferred[]?' "$CONFIG_FILE" 2>/dev/null)
else
  echo "opencode-llm-probe: $CONFIG_FILE not found — using built-in fallback" >&2
  PREFERRED=(
    opencode/deepseek-v4-flash-free
    opencode/mimo-v2.5-free
    opencode/hy3-free
    opencode/big-pickle
  )
fi

[ ${#PREFERRED[@]} -gt 0 ] || die "no preferred models defined"

# --- try to discover available models ----------------------------------------
AVAILABLE=()
NOTE=""
DISCOVERED=()

if ! command -v opencode >/dev/null 2>&1; then
  NOTE="opencode CLI not found — using preferred list"
  FINAL=("${PREFERRED[@]}")

elif ! output=$(opencode models opencode --format json 2>/dev/null); then
  NOTE="could not reach OpenCode (auth?) — using preferred list; run 'opencode providers login'"
  FINAL=("${PREFERRED[@]}")

else
  # Parse the JSON array of model names
  mapfile -t ALL_MODELS < <(echo "$output" | jq -r '.[].name // .[] // empty' 2>/dev/null || true)
  if [ ${#ALL_MODELS[@]} -eq 0 ]; then
    # Maybe the output is a flat list of strings or table rows
    mapfile -t ALL_MODELS < <(echo "$output" | jq -r '.[] // empty' 2>/dev/null || true)
  fi
  if [ ${#ALL_MODELS[@]} -eq 0 ]; then
    # Try parsing as text table (assume first column = model name)
    mapfile -t ALL_MODELS < <(opencode models opencode 2>/dev/null \
      | awk 'NR>2 {print $1}' | grep -v '^$' || true)
  fi

  if [ ${#ALL_MODELS[@]} -eq 0 ]; then
    NOTE="opencode models returned no parseable output — using preferred list"
    FINAL=("${PREFERRED[@]}")
  else
    # Match preferred against available — keep in order
    MATCHES=()
    MISSING=()
    for m in "${PREFERRED[@]}"; do
      found=0
      for a in "${ALL_MODELS[@]}"; do
        if [ "$m" = "$a" ] || [ "${m#opencode/}" = "${a#opencode/}" ]; then
          MATCHES+=("$m")
          found=1
          break
        fi
      done
      [ "$found" -eq 0 ] && MISSING+=("$m")
    done

    if [ ${#MATCHES[@]} -gt 0 ]; then
      FINAL=("${MATCHES[@]}")
      REMOVED=""
      [ ${#MISSING[@]} -gt 0 ] && REMOVED=" (removed: ${MISSING[*]})"
      NOTE="verified${REMOVED}"
    else
      # All preferred missing — discover free-tier alternatives from ALL_MODELS
      for a in "${ALL_MODELS[@]}"; do
        case "$a" in
          *free*|*Free*|*FREE*) DISCOVERED+=("$a") ;;
        esac
      done
      if [ ${#DISCOVERED[@]} -gt 0 ]; then
        FINAL=("${DISCOVERED[@]}")
        NOTE="no preferred models available — using discovered: ${DISCOVERED[*]}"
      else
        FINAL=("${PREFERRED[@]}")
        NOTE="no recognized models found — using preferred list anyway"
      fi
    fi
  fi
fi

# --- write state file --------------------------------------------------------
json=$(jq -n \
  --arg at "$PROBED_AT" \
  --arg note "${NOTE:-null}" \
  --argjson models "$(printf '%s\n' "${FINAL[@]}" | jq -R . | jq -s .)" \
  '{probed_at:$at, models:$models, note:($note|if .=="" then null else . end)}')

tmp="$STATE_FILE.$$.tmp"
printf '%s\n' "$json" >"$tmp" || die "could not write $tmp"
mv -f "$tmp" "$STATE_FILE" || die "could not move state file into place"

# --- one-line summary --------------------------------------------------------
echo "opencode-llm-models: ${NOTE:-verified} (${#FINAL[@]} models)"
