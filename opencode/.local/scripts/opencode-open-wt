#!/usr/bin/env bash
# opencode-open-wt — open an editor in an opencode-wt session worktree.
set -euo pipefail

usage() {
  cat <<EOF
Usage:
  opencode-open-wt <editor> <name>  Open <editor> in session worktree <name>,
                                    e.g.:
                                      opencode-open-wt code feature-auth
                                      opencode-open-wt nvim feature-auth
  opencode-open-wt -h, --help       Show this help.

Worktrees live under <repo>/.worktrees/ (list them: opencode-wt -l).
EOF
}

die() {
  echo "opencode-open-wt: $*" >&2
  exit 1
}

case "${1:-}" in
  -h | --help)
    usage
    exit 0
    ;;
  "" | -*)
    usage >&2
    exit 1
    ;;
esac

[ $# -ge 2 ] || { usage >&2; exit 1; }

editor=$1
name=$2

common=$(git rev-parse --path-format=absolute --git-common-dir 2>/dev/null) ||
  die "not inside a git repository"
root=$(dirname "$common")

wt_dir="$root/.worktrees/$name"
[ -d "$wt_dir" ] || die "no worktree named '$name' (see opencode-wt -l)"
[ -f "$wt_dir/.git" ] || die "'$name' exists but is not a worktree (try: git worktree prune)"

cd "$wt_dir" && exec "$editor" .
