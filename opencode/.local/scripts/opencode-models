#!/usr/bin/env bash
set -euo pipefail

CONFIG="${XDG_CONFIG_HOME:-$HOME/.config}/opencode/opencode-models.json"
# fallback: read from repo if deployed config doesn't exist yet
if [ ! -f "$CONFIG" ]; then
  SELF_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
  CONFIG="$SELF_DIR/../config/opencode-models.json"
fi

USAGE="Usage: opencode-models {relay|free|agents [--list|<name>]}"

cmd="${1:-}"
case "$cmd" in
  relay)
    python3 -c "import json,sys; ms=json.load(open(sys.argv[1]))['relay']; [print(m) for m in ms]" "$CONFIG"
    ;;
  free)
    python3 -c "import json,sys; ms=json.load(open(sys.argv[1]))['free_models']; [print(m) for m in ms]" "$CONFIG"
    ;;
  agents)
    key="${2:-}"
    if [ "$key" = "--list" ]; then
      python3 -c "import json,sys; print('\n'.join(json.load(open(sys.argv[1]))['agents'].keys()))" "$CONFIG"
    elif [ -n "$key" ]; then
      python3 -c "
import json,sys
agents = json.load(open(sys.argv[1]))['agents']
ms = agents.get(sys.argv[2])
if ms is None:
    print(f'Unknown agent: {sys.argv[2]}', file=sys.stderr)
    sys.exit(1)
[print(m) for m in ms]
" "$CONFIG" "$key"
    else
      echo "$USAGE" >&2
      exit 1
    fi
    ;;
  *)
    echo "$USAGE" >&2
    exit 1
    ;;
esac
