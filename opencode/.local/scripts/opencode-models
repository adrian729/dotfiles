#!/usr/bin/env bash
set -euo pipefail

CONFIG="${XDG_CONFIG_HOME:-$HOME/.config}/opencode/opencode-models.json"
# fallback: read from repo if deployed config doesn't exist yet
if [ ! -f "$CONFIG" ]; then
  SELF_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
  CONFIG="$SELF_DIR/../config/opencode-models.json"
fi

USAGE="Usage: opencode-models {relay|free|agents [--list|<name>]}"

cmd="${1:-}"
case "$cmd" in
  relay)
    jq -r '.relay[]' "$CONFIG"
    ;;
  free)
    jq -r '.free_models[]' "$CONFIG"
    ;;
  agents)
    key="${2:-}"
    if [ "$key" = "--list" ]; then
      jq -r '.agents | keys[]' "$CONFIG"
    elif [ -n "$key" ]; then
      jq -r --arg k "$key" '.agents[$k][] // empty' "$CONFIG"
    else
      echo "$USAGE" >&2
      exit 1
    fi
    ;;
  *)
    echo "$USAGE" >&2
    exit 1
    ;;
esac
