#!/usr/bin/env bash
# opencode-agent-models-probe — assign best free model to each agent. Non-fatal.
set -eo pipefail

STATE_DIR="$HOME/.local/state/agents"
STATE_FILE="$STATE_DIR/opencode-agent-models.json"
CONFIG_FILE="${XDG_CONFIG_HOME:-$HOME/.config}/opencode/opencode-models.json"
if [ ! -f "$CONFIG_FILE" ]; then
  SELF_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
  CONFIG_FILE="$SELF_DIR/../config/opencode-models.json"
fi

die() { echo "opencode-agent-models-probe: $*" >&2; exit 1; }
mkdir -p "$STATE_DIR" || die "could not create $STATE_DIR"
PROBED_AT=$(date -u +%Y-%m-%dT%H:%M:%SZ)

# bash 3.2 compat: no mapfile, no associative arrays

# Read agent names from config
AGENT_NAMES=()
while IFS= read -r line; do
  [ -n "$line" ] && AGENT_NAMES+=("$line")
done < <(jq -r '.agents | keys[]' "$CONFIG_FILE" 2>/dev/null || true)
[ ${#AGENT_NAMES[@]} -gt 0 ] || die "no agents found in $CONFIG_FILE"

# Read free_models from config
FREE_MODELS=()
while IFS= read -r line; do
  [ -n "$line" ] && FREE_MODELS+=("$line")
done < <(jq -r '.free_models[]?' "$CONFIG_FILE" 2>/dev/null || true)

# Query available models from both providers
ALL_MODELS=()
NOTE=""

collect_models() {
  local prov="$1" out line
  out=$(opencode models "$prov" 2>/dev/null || true)
  if [ -z "$out" ]; then return 1; fi
  while IFS= read -r line; do
    line="${line%% *}"
    [ -n "$line" ] && ALL_MODELS+=("$line")
  done <<<"$out"
}

AVAILABLE_ANY=false
collect_models opencode && AVAILABLE_ANY=true
collect_models opencode-go 2>/dev/null && AVAILABLE_ANY=true

if ! $AVAILABLE_ANY; then
  NOTE="opencode CLI not reachable (auth?) — using preferred lists unchanged"
  echo "opencode-agent-models-probe: $NOTE" >&2
fi

strip_prov() { local s="$1"; s="${s#opencode/}"; s="${s#opencode-go/}"; echo "$s"; }

# For each agent, find first free+available model
mkdir -p "$STATE_DIR" || true
OVERRIDES_TMP=$(mktemp "${TMPDIR:-/tmp}/opencode-agent-overrides.XXXXXX")
i=0
n="${#AGENT_NAMES[@]}"
while [ "$i" -lt "$n" ]; do
  agent="${AGENT_NAMES[$i]}"
  models_str=$(jq -r ".agents[\"$agent\"][]?" "$CONFIG_FILE" 2>/dev/null | tr '\n' ' ')
  found=""
  for m in $models_str; do
    p=$(strip_prov "$m")
    is_free=0
    for f in "${FREE_MODELS[@]}"; do
      [ "$(strip_prov "$f")" = "$p" ] && { is_free=1; break; }
    done
    [ "$is_free" -eq 0 ] && continue
    for a in "${ALL_MODELS[@]}"; do
      [ "$(strip_prov "$a")" = "$p" ] && { found="$a"; break; }
    done
    [ -n "$found" ] && break
  done
  [ -n "$found" ] && printf '{"%s":{"model":"%s"}}\n' "$agent" "$found" >> "$OVERRIDES_TMP"
  i=$(( i + 1 ))
done

OVERRIDES=$(jq -s '{agent: add}' "$OVERRIDES_TMP" 2>/dev/null || echo '{"agent":{}}')
rm -f "$OVERRIDES_TMP"

AVAIL_JSON=$([ ${#ALL_MODELS[@]} -gt 0 ] && printf '%s\n' "${ALL_MODELS[@]}" | jq -R . | jq -s . 2>/dev/null || echo '[]')

STATE_JSON=$(jq -n \
  --arg at "$PROBED_AT" \
  --arg note "${NOTE:-}" \
  --argjson available "$AVAIL_JSON" \
  --argjson overrides "$OVERRIDES" \
  '{
    probed_at: $at,
    available: $available,
    agent_overrides: $overrides,
    note: ($note | if . == "" then null else . end)
  }'
)

tmp="$STATE_FILE.$$.tmp"
printf '%s\n' "$STATE_JSON" >"$tmp" || die "could not write $tmp"
mv -f "$tmp" "$STATE_FILE" || die "could not move state file into place"

OVERRIDES_FILE="$STATE_DIR/opencode-agent-model-overrides.json"
printf '%s\n' "$OVERRIDES" >"$OVERRIDES_FILE" || die "could not write overrides file"

echo "opencode-agent-models: ${AGENT_NAMES[0]}..${AGENT_NAMES[$((n-1))]} probed ${NOTE:+· $NOTE}"
