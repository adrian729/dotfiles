{
  "$schema": "https://opencode.ai/config.json",
  "server": {
    "port": 42069
  },
  "lsp": {
    "lua-ls": {
      "command": ["lua-language-server"], 
      "extensions": [".lua"],
      "initialization": {
        "runtime": {
          "version": "LuaJIT"
        },
        "workspace": {
          "checkThirdParty": false
        }
      }
    },
    "marksman": {
      "command": ["marksman"],
      "extensions": [".md", ".markdown"]
    }
  },
  "plugin": [
    "opencode-antigravity-auth@latest"
  ]
}
