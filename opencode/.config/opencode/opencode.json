{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [],
  "server": {
    "port": 42069
  },
  "provider": {},
  "permission": {
    "bash": {
      "*": "allow",
      "git push *": "deny"
    }
  },
  "lsp": {
    "lua-ls": {
      "command": ["lua-language-server"],
      "extensions": [".lua"],
      "initialization": {
        "runtime": { "version": "LuaJIT" },
        "workspace": { "checkThirdParty": false }
      }
    },
    "marksman": {
      "command": ["marksman"],
      "extensions": [".md", ".markdown"]
    }
  }
}
