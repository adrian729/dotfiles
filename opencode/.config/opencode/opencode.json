{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [],
  "server": {
    "port": 42069
  },
  "provider": {},
  "permission": {
    "read": "allow",
    "grep": "allow",
    "glob": "allow",
    "list": "allow",
    "lsp": "allow",
    "skill": "allow",
    "question": "allow",
    "webfetch": "allow",
    "websearch": "allow",
    "bash": {
      "*": "allow",
      "llm": "allow",
      "llm *": "allow",
      "llm-probe": "allow",
      "llm-probe *": "allow",
      "ollama ps": "allow",
      "ollama ps *": "allow",
      "ollama list": "allow",
      "ollama list *": "allow",
      "ollama run": "allow",
      "ollama run *": "allow",
      "ollama show": "allow",
      "ollama show *": "allow",
      "opencode-models *": "allow",
      "opencode-agent-models-probe *": "allow",
      "cat *": "allow",
      "bat *": "allow",
      "ls *": "allow",
      "find *": "allow",
      "rg *": "allow",
      "grep *": "allow",
      "head *": "allow",
      "tail *": "allow",
      "awk *": "allow",
      "sed *": "allow",
      "wc *": "allow",
      "sort *": "allow",
      "uniq *": "allow",
      "du *": "allow",
      "df *": "allow",
      "pwd *": "allow",
      "which *": "allow",
      "type *": "allow",
      "whoami *": "allow",
      "date *": "allow",
      "ps *": "allow",
      "printenv *": "allow",
      "git diff *": "allow",
      "git log *": "allow",
      "git status *": "allow",
      "git show *": "allow",
      "git commit": "ask",
      "git commit *": "ask",
      "npm publish": "deny",
      "npm publish *": "deny",
      "gh release": "deny",
      "gh release *": "deny",
      "docker push": "deny",
      "docker push *": "deny",
      "terraform apply": "deny",
      "terraform apply *": "deny",
      "kubectl apply": "deny",
      "kubectl apply *": "deny",
      "cargo publish": "deny",
      "cargo publish *": "deny",
      "git push": "deny",
      "git push *": "deny"
    }
  },
  "agent": {
    "relay": {
      "description": "Text-only relay: answer from the given text alone, no tools.",
      "mode": "primary",
      "hidden": true,
      "permission": {
        "edit": "deny",
        "bash": "deny",
        "read": "deny",
        "glob": "deny",
        "grep": "deny",
        "webfetch": "deny",
        "websearch": "deny",
        "task": "deny",
        "todowrite": "deny",
        "lsp": "deny",
        "skill": "deny",
        "external_directory": "deny"
      },
      "prompt": "You are a text-only relay. Answer the request using only the text given to you in the message. You have no tools and no file, repo, or web access — never claim to check or fetch anything, just answer directly."
    },
    "task": {
      "description": "Full coding agent (bash/edit/read) for headless, unattended runs (see opencode-task) — edit/read/glob tools confined to its --dir; the bash tool is not sandboxed by this setting.",
      "mode": "primary",
      "hidden": true,
      "permission": {
        "external_directory": "deny"
      }
    }
  },
  "lsp": {
    "lua-ls": {
      "command": ["lua-language-server"],
      "extensions": [".lua"],
      "initialization": {
        "runtime": { "version": "LuaJIT" },
        "workspace": { "checkThirdParty": false }
      }
    },
    "marksman": {
      "command": ["marksman"],
      "extensions": [".md", ".markdown"]
    }
  }
}
