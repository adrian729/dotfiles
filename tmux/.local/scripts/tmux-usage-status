#!/usr/bin/env bash

# ‚îÄ‚îÄ AI usage status for tmux ‚Äî shows Claude (brain icon) + OpenCode (star_cog icon)
# Called by tmux via #() in status-right every status-interval (1s).
# Claude data from /tmp/statusline-rate-limits (written by claude's statusline.sh).
# OpenCode data from SQLite DB, cached to /tmp/tmux-opencode-cache (60s stale ‚Üí bg refresh).

# ‚îÄ‚îÄ Icons ‚îÄ‚îÄ
CLAUDE_ICON="Û∞ö©"
OPENCODE_ICON="Û±ô∫"

# ‚îÄ‚îÄ Colors ‚îÄ‚îÄ
CLAUDE_BG="#FAB387"
OPENCODE_BG="#CBA6F7"
SURFACE_0="#313244"
CRUST="#11111B"
GREEN="#A6E3A1"
YELLOW="#F9E2AF"
RED="#F38BA8"

# ‚îÄ‚îÄ Limits ‚îÄ‚îÄ
WINDOW_5H=18000
WINDOW_7D=604800
WINDOW_30D=2592000
LIMIT_5H=12
LIMIT_7D=30
LIMIT_30D=60

# Shared with claude/.claude/statusline.sh, which writes CLAUDE_CACHE ‚Äî keep paths in sync.
CACHE_DIR="${XDG_CACHE_HOME:-$HOME/.cache}/ai-status"
mkdir -p -m 700 "$CACHE_DIR"
chmod 700 "$CACHE_DIR" 2>/dev/null

CACHE_MAX_AGE=10
LOCK_MAX_AGE=60
CLAUDE_CACHE="$CACHE_DIR/statusline-rate-limits"
CLAUDE_WEEKLY_LOG="$HOME/.local/share/claude/weekly-usage.log"
OPENCODE_CACHE="$CACHE_DIR/tmux-opencode-cache"
OPENCODE_DB="$HOME/.local/share/opencode/opencode.db"
LOCK_DIR="$CACHE_DIR/tmux-opencode-refresh.lock"
LOCK_PID_FILE="$LOCK_DIR.pid"

NOW=$(date +%s)

# ‚îÄ‚îÄ Percent formatting ‚îÄ‚îÄ
fmt_pct() {
    local raw=$1 v
    [[ ! "$raw" =~ ^[0-9]+\.?[0-9]*$ ]] && { printf '0%%'; return; }
    v=$(printf "%.1f" "$raw" 2>/dev/null)
    if   (( $(echo "$v < 1" | bc -l) ))  2>/dev/null; then printf '0%%'
    elif (( $(echo "$v < 10" | bc -l) )) 2>/dev/null; then printf '%.1f%%' "$v"
    else printf '%.0f%%' "$v"
    fi
}

# ‚îÄ‚îÄ Color: hard-cap thresholds (OpenCode ‚Äî no reset epoch available) ‚îÄ‚îÄ
threshold_color() {
    local used=$1
    [[ ! "$used" =~ ^[0-9]+\.?[0-9]*$ ]] && { printf '%s' "$GREEN"; return; }
    if   (( $(echo "$used > 80" | bc -l) )) 2>/dev/null; then printf '%s' "$RED"
    elif (( $(echo "$used > 50" | bc -l) )) 2>/dev/null; then printf '%s' "$YELLOW"
    else printf '%s' "$GREEN"
    fi
}

# ‚îÄ‚îÄ Color: pace-aware (Claude ‚Äî compares burn rate to elapsed window time) ‚îÄ‚îÄ
pace_color() {
    local used=$1 reset=$2 win=$3 color="$GREEN" left elapsed over
    (( win <= 0 )) && win=1
    [[ ! "$used" =~ ^[0-9]+\.?[0-9]*$ ]] && { printf '%s' "$GREEN"; return; }
    if [[ "$reset" -gt 0 ]] 2>/dev/null; then
        left=$(( reset - NOW ))
        (( left < 0 )) && left=0
        elapsed=$(( (win - left) * 100 / win ))
        (( elapsed < 0 )) && elapsed=0
        (( elapsed > 100 )) && elapsed=100
        over=$(echo "$used - $elapsed" | bc -l)
        if   (( $(echo "$over >= 20" | bc -l) )) 2>/dev/null; then printf '%s' "$RED"; return
        elif (( $(echo "$over > 0"   | bc -l) )) 2>/dev/null; then printf '%s' "$YELLOW"; return
        fi
    fi
    if   (( $(echo "$used > 80" | bc -l) )) 2>/dev/null; then printf '%s' "$RED"
    elif (( $(echo "$used > 50" | bc -l) )) 2>/dev/null && [[ "$color" = "$GREEN" ]]; then printf '%s' "$YELLOW"
    else printf '%s' "$GREEN"
    fi
}

# ‚îÄ‚îÄ Pill segment: bg hex, icon, left_bg, color1, val1, [color2, val2, ...] ‚îÄ‚îÄ
# left_bg is the arc fill color (previous segment's bg) for seamless transitions
# Each value gets its own color via #[fg=...]
pill() {
    local bg=$1 icon=$2 left_bg=${3:-$CRUST}
    shift 3
    printf '#[fg=%s,bg=%s]#[reverse]ÓÇ∂#[noreverse]#[fg=%s]%s ' "$left_bg" "$bg" "$CRUST" "$icon"
    local sep=""
    while [[ $# -ge 2 ]]; do
        printf '#[fg=%s,bg=%s] %s%s' "$1" "$SURFACE_0" "$sep" "$2"
        sep="| "
        shift 2
    done
    printf ' '
}

# ‚îÄ‚îÄ Refresh OpenCode cache (background, mkdir-locked) ‚îÄ‚îÄ
refresh_opencode_cache() {
    # A refresh process that died mid-run leaves LOCK_DIR behind forever. Reap it only
    # once its pid is confirmed dead (age alone can't tell "dead" from "just slow" and
    # would otherwise let a concurrent invocation steal the lock from a live refresh).
    if [ -d "$LOCK_DIR" ]; then
        lock_pid=$(cat "$LOCK_PID_FILE" 2>/dev/null)
        if [ -z "$lock_pid" ] || ! kill -0 "$lock_pid" 2>/dev/null; then
            lock_age=$(( $(date +%s) - $(stat -f %m "$LOCK_DIR" 2>/dev/null || stat -c %Y "$LOCK_DIR" 2>/dev/null || echo "$NOW") ))
            [ "$lock_age" -gt "$LOCK_MAX_AGE" ] && { rmdir "$LOCK_DIR" 2>/dev/null; rm -f "$LOCK_PID_FILE"; }
        fi
    fi
    if mkdir "$LOCK_DIR" 2>/dev/null; then
        (
            local cost_5h cost_7d cost_30d ts
            if [[ -f "$OPENCODE_DB" ]]; then
                cost_5h=$(sqlite3 "$OPENCODE_DB" \
                    "SELECT COALESCE(SUM(cost), 0) FROM session
                     WHERE time_created > (unixepoch('now') - $WINDOW_5H) * 1000
                     AND json_extract(model, '\$.providerID') = 'opencode-go'" 2>/dev/null) || cost_5h=0
                cost_7d=$(sqlite3 "$OPENCODE_DB" \
                    "SELECT COALESCE(SUM(cost), 0) FROM session
                     WHERE time_created > (unixepoch('now') - $WINDOW_7D) * 1000
                     AND json_extract(model, '\$.providerID') = 'opencode-go'" 2>/dev/null) || cost_7d=0
                cost_30d=$(sqlite3 "$OPENCODE_DB" \
                    "SELECT COALESCE(SUM(cost), 0) FROM session
                     WHERE time_created > (unixepoch('now') - $WINDOW_30D) * 1000
                     AND json_extract(model, '\$.providerID') = 'opencode-go'" 2>/dev/null) || cost_30d=0
            else
                cost_5h=0; cost_7d=0; cost_30d=0
            fi
            ts=$(date +%s)
            tmp=$(mktemp "${OPENCODE_CACHE}.XXXXXX") && \
                printf '{"cost_5h":%s,"cost_7d":%s,"cost_30d":%s,"ts":%s}\n' \
                "$cost_5h" "$cost_7d" "$cost_30d" "$ts" > "$tmp" && \
                mv -f "$tmp" "$OPENCODE_CACHE"
            rm -f "$LOCK_PID_FILE"
            rmdir "$LOCK_DIR"
        ) &
        echo $! > "$LOCK_PID_FILE"
    fi
}

# ‚îÄ‚îÄ Read OpenCode cache, trigger bg refresh if stale ‚îÄ‚îÄ
read_opencode() {
    local stale=1 o_ts
    if [[ -f "$OPENCODE_CACHE" ]]; then
        o_ts=$(jq -r '.ts // 0' "$OPENCODE_CACHE" 2>/dev/null)
        [[ "$o_ts" -gt $((NOW - CACHE_MAX_AGE)) ]] 2>/dev/null && stale=0
    fi
    [[ "$stale" -eq 1 ]] && refresh_opencode_cache
    if [[ -f "$OPENCODE_CACHE" ]]; then
        o_cost_5h=$(jq -r '.cost_5h // 0'  "$OPENCODE_CACHE" 2>/dev/null) || o_cost_5h=0
        o_cost_7d=$(jq -r '.cost_7d // 0'  "$OPENCODE_CACHE" 2>/dev/null) || o_cost_7d=0
        o_cost_30d=$(jq -r '.cost_30d // 0' "$OPENCODE_CACHE" 2>/dev/null) || o_cost_30d=0
    fi
    : "${o_cost_5h:=0}" "${o_cost_7d:=0}" "${o_cost_30d:=0}"
}

# ‚îÄ‚îÄ Read Claude cache ‚îÄ‚îÄ
read_claude() {
    c_5h_pct=0; c_7d_pct=0; c_5h_reset=0; c_7d_reset=0; c_monthly_pct=0
    if [[ -f "$CLAUDE_CACHE" ]]; then
        IFS='|' read -r c_5h_pct c_7d_pct c_5h_reset c_7d_reset < "$CLAUDE_CACHE" 2>/dev/null
    fi
    : "${c_5h_pct:=0}" "${c_7d_pct:=0}" "${c_5h_reset:=0}" "${c_7d_reset:=0}"
    if [[ -f "$CLAUDE_WEEKLY_LOG" ]]; then
        local prev_sum=0 pct
        while IFS='|' read -r _ pct _; do
            [[ "$pct" =~ ^[0-9]+\.?[0-9]*$ ]] && prev_sum=$(echo "$prev_sum + $pct" | bc -l 2>/dev/null)
        done < <(tail -3 "$CLAUDE_WEEKLY_LOG" 2>/dev/null)
        c_monthly_pct=$(echo "scale=2; ($c_7d_pct + $prev_sum) / 4" | bc -l 2>/dev/null) || c_monthly_pct=0
    else
        c_monthly_pct=$(echo "scale=2; $c_7d_pct / 4" | bc -l 2>/dev/null) || c_monthly_pct=0
    fi
}

# ‚îÄ‚îÄ Main ‚îÄ‚îÄ
read_claude
read_opencode

# OpenCode percentages (multiply first to avoid bc scale truncation)
o_5h_pct=$( echo "scale=4; ${o_cost_5h:-0} * 100 / $LIMIT_5H"  | bc -l 2>/dev/null) || o_5h_pct=0
o_7d_pct=$( echo "scale=4; ${o_cost_7d:-0} * 100 / $LIMIT_7D"  | bc -l 2>/dev/null) || o_7d_pct=0
o_30d_pct=$(echo "scale=4; ${o_cost_30d:-0} * 100 / $LIMIT_30D" | bc -l 2>/dev/null) || o_30d_pct=0

# Colors
c_5h_color=$(pace_color "$c_5h_pct" "$c_5h_reset" "$WINDOW_5H")
c_7d_color=$(pace_color "$c_7d_pct" "$c_7d_reset" "$WINDOW_7D")
c_monthly_color=$(threshold_color "$c_monthly_pct")

o_5h_color=$(threshold_color "$o_5h_pct")
o_7d_color=$(threshold_color "$o_7d_pct")
o_30d_color=$(threshold_color "$o_30d_pct")

# Format values
c_5h_fmt=$(fmt_pct "$c_5h_pct")
c_7d_fmt=$(fmt_pct "$c_7d_pct")
c_monthly_fmt=$(fmt_pct "$c_monthly_pct")
o_5h_fmt=$(fmt_pct "$o_5h_pct")
o_7d_fmt=$(fmt_pct "$o_7d_pct")
o_30d_fmt=$(fmt_pct "$o_30d_pct")

# Render two pills
pill "$CLAUDE_BG"   "$CLAUDE_ICON"   "$CRUST"     "$c_5h_color" "$c_5h_fmt" "$c_7d_color" "$c_7d_fmt" "$c_monthly_color" "$c_monthly_fmt"
pill "$OPENCODE_BG" "$OPENCODE_ICON" "$SURFACE_0" "$o_5h_color" "$o_5h_fmt" "$o_7d_color" "$o_7d_fmt" "$o_30d_color" "$o_30d_fmt"
