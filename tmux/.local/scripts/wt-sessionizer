#!/usr/bin/env bash
# wt-sessionizer — fzf picker over worktrees; select, then choose claude or opencode.
set -euo pipefail

command -v fzf >/dev/null 2>&1 || {
  echo "wt-sessionizer: fzf is required (brew install fzf / apt install fzf)" >&2
  sleep 2
  exit 1
}

git rev-parse --path-format=absolute --git-common-dir >/dev/null 2>&1 || {
  echo "wt-sessionizer: not inside a git repository" >&2
  sleep 2
  exit 1
}

query=""
while true; do
  listing=$(claude-wt -l)
  rows=$(awk 'NR>1' <<<"$listing")
  names=$(awk 'NR>1{print $1}' <<<"$listing")

  if result=$(fzf --print-query --expect=ctrl-n --query="$query" \
      --header='enter: select   ctrl-n: create new (type name above)' <<<"$rows"); then
    rc=0
  else
    rc=$?
  fi
  [ "$rc" -eq 130 ] && exit 0
  query=$(sed -n 1p <<<"$result")
  key=$(sed -n 2p <<<"$result")
  sel=$(sed -n 3p <<<"$result")
  name=""

  case "$key" in
    ctrl-n)
      name=$(sed 's/^[[:space:]]*//;s/[[:space:]]*$//' <<<"$query")
      if ! git check-ref-format --branch "$name" >/dev/null 2>&1; then
        echo "wt-sessionizer: '$name' is not a valid worktree/branch name" >&2
        sleep 1.5; continue
      fi
      if grep -qxF "$name" <<<"$names"; then
        echo "wt-sessionizer: '$name' already exists — select it from the list" >&2
        sleep 1.5; continue
      fi
      ;;
    *)
      if [ -n "$sel" ]; then
        name=$(awk '{print $1}' <<<"$sel")
      elif [ -n "$query" ]; then
        echo "wt-sessionizer: no match — press ctrl-n to create '$query'" >&2
        sleep 1.5; continue
      else
        exit 0
      fi
      ;;
  esac

  color=""
  saved=$(git config --get "wt.$name.color" 2>/dev/null || true)

  while true; do
    if [ -n "$color" ]; then
      printf '\nColor: %s.  ' "$color"
    elif [ -n "$saved" ]; then
      printf '\nColor: %s (saved).  ' "$saved"
    else
      printf '\n'
    fi
    printf '[c]laude  [o]pencode  [q]uit  (or type a color): '
    read -r choice
    case "$choice" in
      c)
        final_color=${color:-$saved}
        exec claude-wt "$name" ${final_color:+"$final_color"}
        ;;
      o)
        final_color=${color:-$saved}
        exec opencode-wt "$name" ${final_color:+"$final_color"}
        ;;
      q) query=""; continue 2 ;;
      *)
        if grep -qxF "$choice" <<'EOF'
red
maroon
peach
yellow
green
teal
sky
sapphire
blue
lavender
mauve
pink
flamingo
rosewater
EOF
        then
          color="$choice"
        else
          echo "wt-sessionizer: unknown color '$choice'"
        fi
        ;;
    esac
  done
done
