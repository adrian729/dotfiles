#!/usr/bin/env bash
# wt-sessionizer — fzf picker over worktrees; select, then choose claude or opencode.
set -euo pipefail

COLORS="red maroon peach yellow green teal sky sapphire blue lavender mauve pink flamingo rosewater"

color_fg() {
  case "$1" in
    red)       printf '\033[38;2;243;139;168m' ;;
    maroon)    printf '\033[38;2;235;160;172m' ;;
    peach)     printf '\033[38;2;250;179;135m' ;;
    yellow)    printf '\033[38;2;249;226;175m' ;;
    green)     printf '\033[38;2;166;227;161m' ;;
    teal)      printf '\033[38;2;148;226;213m' ;;
    sky)       printf '\033[38;2;137;220;235m' ;;
    sapphire)  printf '\033[38;2;116;199;236m' ;;
    blue)      printf '\033[38;2;137;180;250m' ;;
    lavender)  printf '\033[38;2;180;190;254m' ;;
    mauve)     printf '\033[38;2;203;166;247m' ;;
    pink)      printf '\033[38;2;245;194;231m' ;;
    flamingo)  printf '\033[38;2;242;205;205m' ;;
    rosewater) printf '\033[38;2;245;224;220m' ;;
    *) return 1 ;;
  esac
}

match_color() {
  local input=$1 color
  for color in $COLORS; do
    [ "$input" = "$color" ] && { echo "$color"; return 0; }
  done
  for color in $COLORS; do
    case "$color" in "$input"*) echo "$color"; return 0 ;; esac
  done
  for color in $COLORS; do
    case "$color" in *"$input"*) echo "$color"; return 0 ;; esac
  done
  return 1
}

command -v fzf >/dev/null 2>&1 || {
  echo "wt-sessionizer: fzf is required (brew install fzf / apt install fzf)" >&2
  sleep 2
  exit 1
}

git rev-parse --path-format=absolute --git-common-dir >/dev/null 2>&1 || {
  echo "wt-sessionizer: not inside a git repository" >&2
  sleep 2
  exit 1
}

query=""
while true; do
  listing=$(claude-wt -l)
  rows=$(awk 'NR>1' <<<"$listing")
  names=$(awk 'NR>1{print $1}' <<<"$listing")

  if result=$(fzf --print-query --expect=ctrl-n --query="$query" \
      --header='enter: select   ctrl-n: create new (type name above)' <<<"$rows"); then
    rc=0
  else
    rc=$?
  fi
  [ "$rc" -eq 130 ] && exit 0
  query=$(sed -n 1p <<<"$result")
  key=$(sed -n 2p <<<"$result")
  sel=$(sed -n 3p <<<"$result")
  name=""

  case "$key" in
    ctrl-n)
      name=$(sed 's/^[[:space:]]*//;s/[[:space:]]*$//' <<<"$query")
      if ! git check-ref-format --branch "$name" >/dev/null 2>&1; then
        echo "wt-sessionizer: '$name' is not a valid worktree/branch name" >&2
        sleep 1.5; continue
      fi
      if grep -qxF "$name" <<<"$names"; then
        echo "wt-sessionizer: '$name' already exists — select it from the list" >&2
        sleep 1.5; continue
      fi
      ;;
    *)
      if [ -n "$sel" ]; then
        name=$(awk '{print $1}' <<<"$sel")
      elif [ -n "$query" ]; then
        echo "wt-sessionizer: no match — press ctrl-n to create '$query'" >&2
        sleep 1.5; continue
      else
        exit 0
      fi
      ;;
  esac

  color=""
  saved=$(git config --get "wt.$name.color" 2>/dev/null || true)

  while true; do
    if [ -n "$color" ]; then
      printf 'selected '
      color_fg "$color"
      printf '■ %s' "$color"
      printf '\033[39m color\n'
    elif [ -n "$saved" ]; then
      printf 'color: '
      color_fg "$saved"
      printf '■ %s' "$saved"
      printf '\033[39m (saved)\n'
    fi
    printf '[c]laude  [o]pencode  [l]ist colors  [q]uit  (type color to pick): '
    read -rs -n 1 first 2>/dev/null || exit 0
    if [ "$first" = $'\033' ]; then
      query=""
      continue 2
    fi
    read -r rest
    choice="$first$rest"
    case "$choice" in
      c)
        final_color=${color:-$saved}
        exec claude-wt "$name" ${final_color:+"$final_color"}
        ;;
      o)
        final_color=${color:-$saved}
        exec opencode-wt "$name" ${final_color:+"$final_color"}
        ;;
      q) exit 0 ;;
      l)
        echo ""
        i=0
        for c in $COLORS; do
          color_fg "$c"
          printf '■ %s' "$c"
          printf '\033[39m  '
          i=$((i + 1))
          [ "$((i % 7))" -eq 0 ] && echo ""
        done
        [ "$((i % 7))" -ne 0 ] && echo ""
        ;;
      *)
        if matched=$(match_color "$choice"); then
          color="$matched"
        else
          echo "wt-sessionizer: unknown color '$choice'"
        fi
        ;;
    esac
  done
done
