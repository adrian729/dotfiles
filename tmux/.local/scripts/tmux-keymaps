#!/usr/bin/env bash

# fzf-searchable tmux keymap viewer — all tables, search by key or command.
{
  printf '%-20s  %-12s  %s\n' 'KEY' 'TABLE' 'COMMAND'
  tmux list-keys -a \
    | sed -E 's/  +/ /g' \
    | while read -r _ _ table key rest; do
        printf '%-20s  %-12s  %s\n' "$key" "$table" "$rest"
      done
} | FZF_DEFAULT_OPTS= fzf \
    --prompt='keymap> ' \
    --header-lines=1
